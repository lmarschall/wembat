  "version": "0.9.4",
  "description": "",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/src/app.js",
    "serve": "tsc && node dist/src/app.js",
    "lint": "eslint --ext .js,.vue --ignore-path .gitignore --fix ./src/**/*.ts",
    "format": "prettier ./src/**/*.ts --write",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "imports": {
    "#prisma": "./dist/prisma/generated/client.js",
